# Webflow API token — shared across cities (typical case: one Webflow
# workspace, multiple sites). If a city's Webflow site lives in a
# different workspace, set its token via a different env var name and
# reference it in cities.json via `webflowApiTokenEnvVar`.
WEBFLOW_API_TOKEN=your_webflow_api_token_here

# Webflow webhook signing secret — used by api/webflow-webhook.ts to
# verify incoming webhook signatures. Set the same value when registering
# the webhook in the Webflow dashboard.
WEBFLOW_WEBHOOK_SECRET=

# GitHub repo (owner/repo) and PAT used by the webhook receiver to
# trigger workflow_dispatch on the sync action.
GITHUB_REPO=CerkaB/tulum-cms-sync
GITHUB_DISPATCH_TOKEN=

# Optional: when set, sync.ts only syncs this one city and skips the
# rest. Used by the webhook receiver via workflow input to scope syncs
# to the city whose Webflow site fired the event. Leave unset to sync
# every active city in cities.json.
# SYNC_ONLY_CITY=tulum
